{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "memory": 3009,
      "maxDuration": 60
    },
    "api/login.ts": { "maxDuration": 10 },
    "api/register.ts": { "maxDuration": 10 },
    "api/teacher-verification-status.ts": { "maxDuration": 10 },
    "api/salary-pdf.ts": { "maxDuration": 15 },
    "api/password-reset-request.ts": { "maxDuration": 10 },
    "api/password-reset.ts": { "maxDuration": 10 },
    "api/account.ts": { "maxDuration": 10 },
    "api/students.ts": { "maxDuration": 10 },
    "api/schedules.ts": { "maxDuration": 10 },
    "api/achievements.ts": { "maxDuration": 10 },
    "api/prompts.ts": { "maxDuration": 30 },
    "api/creative.ts": { "maxDuration": 10 },
    "api/liferecords.ts": { "maxDuration": 30 },
    "api/meals.ts": { "maxDuration": 10 },
    "api/autobiography.ts": { "maxDuration": 60 },
    "api/care-classroom.ts": { "maxDuration": 10 },
    "api/observations.ts": { "maxDuration": 10 },
    "api/question-answers.ts": { "maxDuration": 10 },
    "api/digest.ts": { "maxDuration": 10 },
    "api/digest-jobs.ts": { "maxDuration": 15 },
    "api/autobiography-projects.ts": { "maxDuration": 15 },
    "api/generate-chapter.ts": { "maxDuration": 30 },
    "api/schedule-reflections.ts": { "maxDuration": 10 },
    "api/proofread.ts": { "maxDuration": 15 },
    "api/schema-check.ts": { "maxDuration": 10 },
    "api/activity-metadata.ts": { "maxDuration": 10 },
    "api/qr-session.ts": { "maxDuration": 10 },
    "api/creative-collections.ts": { "maxDuration": 10 },
    "api/student-submissions.ts": { "maxDuration": 10 },
    "api/classes.ts": { "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/api/users/login", "destination": "/api/login" },
    { "source": "/users/login", "destination": "/api/login" },
    { "source": "/api/users/register", "destination": "/api/register" },
    { "source": "/users/register", "destination": "/api/register" },
    { "source": "/teacher-verification/status", "destination": "/api/teacher-verification-status" },
    { "source": "/teacher-verification/salary-pdf", "destination": "/api/salary-pdf" },
    { "source": "/api/password-reset-request", "destination": "/api/password-reset-request" },
    { "source": "/api/password-reset", "destination": "/api/password-reset" },
    { "source": "/api/account", "destination": "/api/account" },
    { "source": "/api/students", "destination": "/api/students" },
    { "source": "/api/schedules", "destination": "/api/schedules" },
    { "source": "/api/achievements", "destination": "/api/achievements" },
    { "source": "/api/prompts", "destination": "/api/prompts" },
    { "source": "/api/creative", "destination": "/api/creative" },
    { "source": "/api/liferecords", "destination": "/api/liferecords" },
    { "source": "/api/meals", "destination": "/api/meals" },
    { "source": "/api/autobiography", "destination": "/api/autobiography" },
    { "source": "/api/care-classroom", "destination": "/api/care-classroom" },
    { "source": "/api/observations", "destination": "/api/observations" },
    { "source": "/api/question-answers", "destination": "/api/question-answers" },
    { "source": "/api/digest", "destination": "/api/digest" },
    { "source": "/api/digest-jobs", "destination": "/api/digest-jobs" },
    { "source": "/api/autobiography-projects", "destination": "/api/autobiography-projects" },
    { "source": "/api/generate-chapter", "destination": "/api/generate-chapter" },
    { "source": "/api/schedule-reflections", "destination": "/api/schedule-reflections" },
    { "source": "/api/proofread", "destination": "/api/proofread" },
    { "source": "/api/schema-check", "destination": "/api/schema-check" },
    { "source": "/api/activity-metadata", "destination": "/api/activity-metadata" },
    { "source": "/api/qr-session", "destination": "/api/qr-session" },
    { "source": "/api/creative-collections", "destination": "/api/creative-collections" },
    { "source": "/api/student-submissions", "destination": "/api/student-submissions" },
    { "source": "/api/classes", "destination": "/api/classes" },
    { "source": "/(.*)", "destination": "/api/index" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/health",
      "schedule": "*/5 * * * *"
    }
  ]
}
