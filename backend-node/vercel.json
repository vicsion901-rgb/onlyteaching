{
  "version": 2,
  "builds": [
    {
      "src": "api/login.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/register.ts",
      "use": "@vercel/node"
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/users/login",
      "dest": "/api/login.ts"
    },
    {
      "src": "/users/login",
      "dest": "/api/login.ts"
    },
    {
      "src": "/api/users/register",
      "dest": "/api/register.ts"
    },
    {
      "src": "/users/register",
      "dest": "/api/register.ts"
    },
    {
      "src": "/api/swagger-ui-init.js",
      "dest": "/api/swagger-ui-init.js"
    },
    {
      "src": "/api/swagger-ui-bundle.js",
      "dest": "/api/swagger-ui-bundle.js"
    },
    {
      "src": "/api/swagger-ui-standalone-preset.js",
      "dest": "/api/swagger-ui-standalone-preset.js"
    },
    {
      "src": "/api/swagger-ui.css",
      "dest": "/api/swagger-ui.css"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "crons": [
    {
      "path": "/health",
      "schedule": "*/5 * * * *"
    }
  ]
}
